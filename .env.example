# FinanceMCP Gate A configuration. Copy to .env (chmod 600), never commit.
PORT=8788
# Public issuer URL. Local dev: http://localhost:8788  Prod: https://finance.rteam.agency
BASE_URL=http://localhost:8788
# Single-user login for the OAuth consent screen (Gate A; real signup comes with Supabase in M1)
FINANCE_MCP_EMAIL=alex@rteam.top
# Generate: bun -e "console.log(await Bun.password.hash(process.argv[1]))" 'your-password'
FINANCE_MCP_PASSWORD_HASH=
# Where the OAuth JSON store lives
STATE_DIR=./state
