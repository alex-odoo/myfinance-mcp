# MyFinance MCP configuration. Copy to .env locally (chmod 600); on the server it
# lives as app.env (compose env_file format:raw). Never commit either.
PORT=8788
# Public issuer URL. Local dev: http://localhost:8788  Prod: https://your-domain.com
BASE_URL=http://localhost:8788
# Bootstrap user for the OAuth sign-in screen (created in the users table at boot)
MYFINANCE_MCP_EMAIL=you@example.com
# Generate: bun -e "console.log(await Bun.password.hash(process.argv[1]))" 'your-password'
MYFINANCE_MCP_PASSWORD_HASH=
# Postgres connection string. Supabase works well: use the session pooler (IPv4) URL.
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
# Google sign-in (optional: button + /auth/google routes activate only when both set).
# Google Cloud Console OAuth client (Web application); authorized redirect URI:
# <BASE_URL>/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Signup notifications (optional): Resend API key + a verified sender domain.
# Off unless all three are set.
RESEND_API_KEY=
NOTIFY_EMAIL=
FROM_EMAIL=
# Signup notifications via Telegram (optional). Bot token from @BotFather and the
# target chat id (your DM with the bot). Off unless both are set.
# chat_id: message the bot once, then curl https://api.telegram.org/bot<token>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
