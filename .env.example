# MyFinance MCP configuration. Copy to .env locally (chmod 600); on the server it
# lives as app.env (compose env_file format:raw). Never commit either.
PORT=8788
# Public issuer URL. Local dev: http://localhost:8788  Prod: https://myfinance-mcp.com
BASE_URL=http://localhost:8788
# M1 single-user login for the OAuth consent screen (bootstrapped into users table at boot)
MYFINANCE_MCP_EMAIL=alex@rteam.top
# Generate: bun -e "console.log(await Bun.password.hash(process.argv[1]))" 'your-password'
MYFINANCE_MCP_PASSWORD_HASH=
# Supabase Postgres, session pooler (IPv4): project myfinance-mcp, eu-central-1
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-eu-central-1.pooler.supabase.com:5432/postgres
# Google sign-in (optional: button + /auth/google routes activate only when both set).
# Google Cloud Console OAuth client (Web application); authorized redirect URI:
# <BASE_URL>/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Signup notifications (optional): Resend key from the Rteam account; sender domain
# rteam.agency is already verified there. Off when RESEND_API_KEY is empty.
RESEND_API_KEY=
NOTIFY_EMAIL=alex@rteam.top
FROM_EMAIL=notifications@rteam.agency
